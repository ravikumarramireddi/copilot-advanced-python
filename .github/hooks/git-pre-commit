#!/usr/bin/env bash
# Git pre-commit hook: Format Python files with ruff before commit
#
# This hook runs 'ruff format' on all staged Python files before allowing
# the commit to proceed. If formatting changes files, they are re-staged
# automatically.
#
# Installation:
#   ln -sf ../../.github/hooks/git-pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -e

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get list of staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

# Exit early if no Python files are staged
if [ -z "$STAGED_PY_FILES" ]; then
    exit 0
fi

echo -e "${YELLOW}Running ruff format on staged Python files...${NC}"

# Format the staged files
if uv run ruff format $STAGED_PY_FILES; then
    echo -e "${GREEN}✓ Formatting complete${NC}"
    
    # Re-stage the formatted files
    git add $STAGED_PY_FILES
    
    echo -e "${GREEN}✓ Formatted files re-staged${NC}"
    exit 0
else
    echo -e "${RED}✗ Formatting failed${NC}"
    echo "Commit aborted. Please fix formatting issues and try again."
    exit 1
fi
